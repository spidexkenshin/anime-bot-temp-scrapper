# ── Telegram ──────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=123456789:ABCDEFGhijklmnopQRSTUVwxyz

# ── Owner & Storage ───────────────────────────────────────────
# Your personal Telegram user ID (get it from @userinfobot)
OWNER_ID=123456789

# Telegram Group/Channel ID where bot stores videos
# Make sure bot is admin in this group
# Group IDs are usually negative: -100XXXXXXXXXX
STORAGE_GROUP_ID=-1001234567890

# ── MongoDB Atlas ─────────────────────────────────────────────
# Get from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ── Backblaze B2 ──────────────────────────────────────────────
# Get from https://secure.backblaze.com/app_keys.htm
# Create an Application Key with Read + Write access
B2_KEY_ID=your_b2_key_id_here
B2_APPLICATION_KEY=your_b2_application_key_here
B2_BUCKET_NAME=anime-bot-temp
