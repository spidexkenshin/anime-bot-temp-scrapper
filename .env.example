# ── Telegram ──────────────────────────────────────────────────
# Get from https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Get from @BotFather
BOT_TOKEN=123456789:ABCDEFGhijklmnopQRSTUVwxyz

# ── Owner & Storage ───────────────────────────────────────────
# Your personal Telegram user ID (get from @userinfobot)
OWNER_ID=123456789

# Telegram group/channel where bot stores videos
# Bot must be admin in this group with post permission
# IDs are negative: -100XXXXXXXXXX
STORAGE_GROUP_ID=-1001234567890

# ── Backblaze B2 ──────────────────────────────────────────────
# From https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=your_key_id_here
B2_APPLICATION_KEY=your_application_key_here
B2_BUCKET_NAME=anime-bot-temp
